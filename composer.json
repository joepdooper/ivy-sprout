{
  "name": "joepdooper/ivy-sprout",
  "description": "Composer installer for ivy plugins and templates",
  "type": "composer-plugin",
  "license": "MIT",
  "require": {
    "php": ">=8.5.6",
    "composer-plugin-api": "^2.0"
  },
  "require-dev": {
    "composer/composer": "^2.8"
  },
  "autoload": {
    "psr-4": {
      "Ivy\\Sprout\\": "src/"
    }
  },
  "extra": {
    "class": "Ivy\\Sprout\\IvyInstaller"
  }
}